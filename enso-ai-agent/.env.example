# ── Enso Credentials ──────────────────────────────────────────────────────────
# Get these from: app.getenso.ai → Settings → Users → Create API Keys
ENSO_BASE_URL=
ENSO_CLIENT_KEY=
ENSO_CLIENT_SECRET=
ENSO_USERNAME=

# ── Gemini ─────────────────────────────────────────────────────────────────────
# Get from: aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Slack ──────────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN  → api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
# SLACK_SIGNING_SECRET → api.slack.com/apps → Basic Information → Signing Secret
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── MCP Server ─────────────────────────────────────────────────────────────────
# Absolute path to your mcp-server entry point (the file that calls server.start())
MCP_SERVER_PATH=

# ── Express ────────────────────────────────────────────────────────────────────
PORT=4000
